generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StaffRole {
  owner
  partner
  manager
  employee
}

enum SubscriptionStatus {
  trial
  active
  inactive
  cancelled
}

enum BillingCycle {
  monthly
  annual
}

enum SubscriptionPlan {
  plus
  advanced
}

enum StoreSubscriptionStatus {
  pending
  active
  trialing
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused
}

enum StoreFeatureKey {
  lottery
  recipe_suite
  loyalty
  vendor_orders
}

enum StoreFeatureSource {
  setup
  manual
  subscription
  system
}

enum StoreServiceKey {
  loyalty
}

enum StoreServiceStatus {
  not_added
  pending
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
}

enum StoreBusinessType {
  convenience_store
  grocery_store
  supermarket
  liquor_store
  smoke_shop
  vape_shop
  gas_station
  pharmacy
  clothing_store
  shoe_store
  jewelry_store
  gift_shop
  electronics_store
  phone_store
  computer_store
  hardware_store
  home_improvement_store
  furniture_store
  auto_parts
  beauty_store
  pet_store
  bookstore
  toy_store
  flower_shop
  wholesale
  other
}

enum ProductSaleType {
  piece
  weight
  meat_barcode
  service
  lottery
  other
}

enum DepartmentType {
  merchandise
  lottery
  fuel
  misc_services
}

enum DepartmentMinimumAge {
  none
  age_18
  age_18_time_sensitive
  age_21
  age_21_time_sensitive
}

enum TaxStyle {
  pre_discount
  post_discount
}

enum PaymentMethod {
  cash
  card
  ebt
  split
  other
}

enum PaymentStatus {
  paid
  unpaid
  refunded
  partially_refunded
}

enum TransactionStatus {
  completed
  voided
  refunded
  partially_refunded
}

enum CartStatus {
  active
  ready_for_payment
  completed
  cancelled
}

enum InventoryActionType {
  receive
  adjustment
  sale
  return
  spoilage
  waste
  transfer_in
  transfer_out
  manual_edit
}

enum AuditAction {
  create
  update
  delete
  activate
  deactivate
  grant
  revoke
  login
  logout
  system
  proposal_submitted
  proposal_updated
  proposal_approved
  proposal_rejected
  proposal_cancelled
  multi_pack_batch_sent_to_pos
  multi_pack_created
  multi_pack_updated
  multi_pack_deactivated
  multi_pack_reactivated
  pause
  archive
}

enum AuditEntityType {
  store
  store_feature
  product
  payee
  purchase
  department
  price_group
  product_category
  tax
  inventory
  staff_permission
  register
  register_device
  register_activation_code
  customer
  transaction
  cart
  billing
  auth
  multi_pack
  multi_pack_proposal
  multi_pack_batch
  promotion
}

enum PromotionType {
  BUY_X_GET_Y_FREE
  BUY_X_GET_Y_PERCENT_OFF
  BUY_X_GET_Y_FIXED_PRICE
  QUANTITY_BUNDLE_PRICE
  QUANTITY_PERCENT_OFF
  FIXED_AMOUNT_OFF_ITEM
  PERCENT_OFF_ITEM
  FIXED_AMOUNT_OFF_GROUP
  MIX_AND_MATCH_BUNDLE
  SPEND_THRESHOLD_FIXED_OFF
  SPEND_THRESHOLD_PERCENT_OFF
  CUSTOM_PRICE
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  EXPIRED
  INACTIVE
  ARCHIVED
}

enum PromotionConflictStrategy {
  PRIORITY
  BEST_CUSTOMER_DISCOUNT
  BEST_STORE_MARGIN
}

enum PromotionProductRole {
  QUALIFYING
  REWARD
}

enum MultiPackType {
  MULTIPACK_DEAL
  CASE_SALE
}

enum MultiPackStatus {
  ACTIVE
  INACTIVE
}

enum MultiPackProposalAction {
  CREATE
  UPDATE
  DEACTIVATE
  REACTIVATE
}

enum MultiPackProposalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  SUPERSEDED
}

enum CustomerTierDiscountModel {
  ORDER_PERCENTAGE
  ORDER_FLAT_RATE
  ITEM_PERCENTAGE
  ITEM_FLAT_RATE
}

enum StorePermissionKey {
  view_store
  add_store
  edit_store
  delete_store
  manage_products
  manage_multi_pack_pricing
  review_multi_pack_pricing
  manage_inventory
  view_purchases
  manage_purchases
  manage_payees
  manage_customers
  manage_employees
  manage_registers
  view_audit_logs
  view_reports
  process_sales
  override_prices
  view_promotions
  manage_promotions
  activate_promotions
  override_promotions
}

enum RegisterStatus {
  inactive
  active
  revoked
}

enum PurchaseType {
  CASH_DAILY
  CHECK
  CREDIT
}

enum PurchaseStatus {
  DRAFT
  OPEN
  VERIFIED
  VOIDED
}

enum PayeeType {
  VENDOR
  MISC
  EXPENSE
}

enum VendorOrderStatus {
  DRAFT
  READY
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model Staff {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  role            StaffRole
  emailVerifiedAt DateTime?

  owner    Owner?
  partner  Partner?
  manager  Manager?
  employee Employee?

  storeStaff                     StoreStaff[]
  passwordResetTokens            PasswordResetToken[]
  emailVerificationTokens        EmailVerificationToken[]
  inventoryLogs                  InventoryLog[]
  auditEvents                    AuditEvent[]
  transactions                   Transaction[]
  carts                          Cart[]
  createdRegisterActivationCodes RegisterActivationCode[]
  purchasesCreated               Purchase[]               @relation("PurchaseCreatedBy")
  purchasesUpdated               Purchase[]               @relation("PurchaseUpdatedBy")
  promotionsCreated              Promotion[]              @relation("PromotionCreatedBy")
  promotionsUpdated              Promotion[]              @relation("PromotionUpdatedBy")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model Owner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  stores Store[]

  subscriptions     Subscription[]
  customerTiers     CustomerTier[]
  customerTierRules CustomerTierRule[]
  auditEvents       AuditEvent[]
}

model Partner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Manager {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  permissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Employee {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Store {
  id                 String            @id @default(uuid())
  name               String
  address            String?
  businessType       StoreBusinessType @default(other)
  nextProductNumber  Int               @default(1)
  nextPurchaseNumber Int               @default(1)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  staff                   StoreStaff[]
  products                Product[]
  productMultiPacks       ProductMultiPack[]
  multiPackProposals      MultiPackProposal[]
  inventoryLogs           InventoryLog[]
  departments             Department[]
  priceGroups             PriceGroup[]
  productCategories       ProductCategory[]
  taxes                   Tax[]
  payees                  Payee[]
  productVendors          ProductVendor[]
  vendorOrders            VendorOrder[]
  purchases               Purchase[]
  customers               CustomerStore[]
  customerTiers           CustomerTier[]
  customerTierRules       CustomerTierRule[]
  customerPurchaseHistory CustomerPurchaseHistory[]
  transactions            Transaction[]
  carts                   Cart[]
  registers               Register[]
  registerActivationCodes RegisterActivationCode[]
  registerDevices         RegisterDevice[]
  storeSubscription       StoreSubscription?
  features                StoreFeature[]
  serviceSubscriptions    StoreServiceSubscription[]
  auditEvents             AuditEvent[]
  promotions              Promotion[]

  @@index([ownerId, isActive])
}

model AuditEvent {
  id         String          @id @default(uuid())
  storeId    String
  actorId    String?
  ownerId    String?
  action     AuditAction
  entityType AuditEntityType
  entityId   String?
  entityName String?
  summary    String
  before     Json?
  after      Json?
  changes    Json?
  metadata   Json?
  requestId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())

  store Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  actor Staff? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  owner Owner? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([storeId, action, createdAt])
  @@index([storeId, entityType, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

model StoreSubscription {
  id String @id @default(uuid())

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  plan                     SubscriptionPlan
  status                   StoreSubscriptionStatus @default(pending)
  stripeCustomerId         String?
  stripeSubscriptionId     String?                 @unique
  stripeCheckoutSessionId  String?                 @unique
  stripePriceId            String?
  checkoutAttemptId        String?
  checkoutIdempotencyKey   String?
  checkoutSessionExpiresAt DateTime?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean                 @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

model StoreFeature {
  id        String             @id @default(uuid())
  storeId   String
  feature   StoreFeatureKey
  enabled   Boolean            @default(false)
  source    StoreFeatureSource
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, feature])
  @@index([storeId, enabled])
}

model StoreServiceSubscription {
  id                       String             @id @default(uuid())
  storeId                  String
  service                  StoreServiceKey
  status                   StoreServiceStatus @default(pending)
  stripeSubscriptionId     String?
  stripeSubscriptionItemId String?            @unique
  stripePriceId            String?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, service])
  @@index([storeId, status])
}

model StripeWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

model Register {
  id             String         @id @default(uuid())
  storeId        String
  name           String
  registerNumber String
  description    String?
  deviceName     String?
  status         RegisterStatus @default(inactive)
  activatedAt    DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  store           Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  activationCodes RegisterActivationCode[]
  devices         RegisterDevice[]
  transactions    Transaction[]

  @@unique([storeId, registerNumber])
  @@index([storeId, status])
}

model RegisterActivationCode {
  id               String    @id @default(uuid())
  registerId       String
  storeId          String
  codeHash         String
  expiresAt        DateTime
  usedAt           DateTime?
  createdByStaffId String
  createdAt        DateTime  @default(now())

  register       Register @relation(fields: [registerId], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByStaff Staff    @relation(fields: [createdByStaffId], references: [id])

  @@index([registerId, usedAt, expiresAt])
  @@index([storeId])
  @@index([createdByStaffId])
}

model RegisterDevice {
  id                String    @id @default(uuid())
  registerId        String
  storeId           String
  deviceFingerprint String?
  deviceName        String?
  deviceTokenHash   String    @unique
  isActive          Boolean   @default(true)
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  revokedAt         DateTime?

  register Register @relation(fields: [registerId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([registerId, isActive])
  @@index([storeId, isActive])
}

model StoreStaff {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  role StaffRole

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  managerId String?
  manager   Manager? @relation(fields: [managerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  permissions StoreStaffPermission[]

  @@unique([storeId, staffId])
}

model StoreStaffPermission {
  id           String             @id @default(uuid())
  storeStaffId String
  permission   StorePermissionKey
  createdAt    DateTime           @default(now())

  storeStaff StoreStaff @relation(fields: [storeStaffId], references: [id], onDelete: Cascade)

  @@unique([storeStaffId, permission])
  @@index([storeStaffId])
}

model Subscription {
  id String @id @default(uuid())

  status              SubscriptionStatus @default(trial)
  plan                SubscriptionPlan   @default(plus)
  billingCycle        BillingCycle
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  maxStores           Int?
  activeStoreCount    Int                @default(0)
  pricePerStore       Float              @default(0)
  totalMonthlyAmount  Float              @default(0)
  totalAnnualAmount   Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  addons SubscriptionAddon[]

  @@index([ownerId, status])
}

model SubscriptionAddon {
  id             String   @id @default(uuid())
  subscriptionId String
  code           String
  name           String
  monthlyAmount  Float
  quantity       Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, code])
  @@index([subscriptionId, isActive])
}

model Product {
  id                             String          @id @default(uuid())
  productNumber                  Int
  barcode                        String
  name                           String
  saleType                       ProductSaleType
  currentQuantity                Int             @default(0)
  unitsPerCase                   Int?
  caseCost                       Float?
  caseDiscount                   Float           @default(0)
  discountPerUnit                Float?
  caseRebate                     Float           @default(0)
  rebatePerUnit                  Float?
  unitCost                       Float?
  unitCostAfterDiscountAndRebate Float?
  unitRetail                     Float
  onlineRetailPrice              Float?
  unitOfMeasure                  String?
  size                           String?
  margin                         Float?
  defaultMargin                  Float?
  maxInventory                   Int?
  minInventory                   Int?
  minimumAge                     Int?
  nacsCode                       String?
  nacsCategory                   String?
  nacsSubCategory                String?
  blueLaw                        Boolean         @default(false)
  linkedItems                    Json?
  kitchenPrint                   Boolean         @default(false)
  allowEbt                       Boolean
  trackInventory                 Boolean         @default(true)
  allowNegativeInventory         Boolean         @default(false)
  taxStyle                       TaxStyle
  isActive                       Boolean         @default(true)
  createdAt                      DateTime        @default(now())
  updatedAt                      DateTime        @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  priceGroupId String?
  priceGroup   PriceGroup? @relation(fields: [priceGroupId], references: [id])

  productCategoryId String?
  productCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])

  taxId String
  tax   Tax    @relation(fields: [taxId], references: [id])

  inventoryLogs        InventoryLog[]
  transactionItems     TransactionItem[]
  purchaseItems        PurchaseItem[]
  productVendors       ProductVendor[]
  vendorOrderItems     VendorOrderItem[]
  cartItems            CartItem[]
  multiPacks           ProductMultiPack[]
  multiPackProposals   MultiPackProposal[]
  promotionAssignments PromotionProduct[]

  @@unique([storeId, barcode])
  @@unique([storeId, productNumber])
  @@index([storeId, isActive])
  @@index([storeId, trackInventory])
  @@index([storeId, currentQuantity])
  @@index([storeId, productNumber])
  @@index([storeId, isActive, productNumber])
  @@index([storeId, departmentId, productNumber])
  @@index([storeId, productCategoryId, productNumber])
  @@index([storeId, priceGroupId, productNumber])
  @@index([departmentId])
  @@index([priceGroupId])
  @@index([productCategoryId])
  @@index([taxId])
}

model Promotion {
  id                                  String                    @id @default(uuid())
  storeId                             String
  name                                String
  description                         String?
  type                                PromotionType
  status                              PromotionStatus           @default(DRAFT)
  startAt                             DateTime?
  endAt                               DateTime?
  priority                            Int                       @default(0)
  stackable                           Boolean                   @default(false)
  conflictStrategy                    PromotionConflictStrategy @default(PRIORITY)
  allowCashierOverride                Boolean                   @default(false)
  requireManagerApproval              Boolean                   @default(false)
  applyAutomatically                  Boolean                   @default(true)
  printOnReceipt                      Boolean                   @default(true)
  displayAtPos                        Boolean                   @default(true)
  stopLowerPriority                   Boolean                   @default(false)
  excludePriceOverrides               Boolean                   @default(true)
  allowRepeatedApplications           Boolean                   @default(true)
  maxApplicationsPerTransaction       Int?
  maxDiscountedQuantityPerTransaction Int?
  limitOneUsePerCustomer              Boolean                   @default(false)
  loyaltyRequired                     Boolean                   @default(false)
  allowEbtProducts                    Boolean                   @default(true)
  applyBeforeTax                      Boolean                   @default(true)
  useSeparateRewardProducts           Boolean                   @default(false)
  configuration                       Json
  internalNotes                       String?
  createdByActorId                    String
  updatedByActorId                    String
  createdAt                           DateTime                  @default(now())
  updatedAt                           DateTime                  @updatedAt
  archivedAt                          DateTime?

  store     Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy Staff              @relation("PromotionCreatedBy", fields: [createdByActorId], references: [id])
  updatedBy Staff              @relation("PromotionUpdatedBy", fields: [updatedByActorId], references: [id])
  products  PromotionProduct[]

  @@index([storeId, status])
  @@index([storeId, startAt, endAt])
  @@index([storeId, type])
  @@index([storeId, updatedAt])
}

model PromotionProduct {
  id          String               @id @default(uuid())
  promotionId String
  productId   String
  role        PromotionProductRole @default(QUALIFYING)
  createdAt   DateTime             @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId, role])
  @@index([promotionId, role])
  @@index([productId])
}

model ProductMultiPack {
  id String @id @default(uuid())

  storeId   String
  productId String

  type            MultiPackType
  unitsPerPack    Int
  caseBarcode     String?
  multiPackRetail Decimal       @db.Decimal(12, 2)

  aggregateCostSnapshot Decimal? @db.Decimal(12, 4)
  marginSnapshot        Decimal? @db.Decimal(8, 4)

  status   MultiPackStatus @default(ACTIVE)
  isActive Boolean         @default(true)
  version  Int             @default(1)

  approvedFromProposalId String?   @unique
  approvedByActorId      String?
  approvedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, productId, isActive])
  @@index([storeId, caseBarcode])
  @@index([storeId, type, isActive])
}

model MultiPackProposal {
  id String @id @default(uuid())

  storeId   String
  productId String

  targetMultiPackId String?
  action            MultiPackProposalAction
  status            MultiPackProposalStatus @default(PENDING)

  proposedType            MultiPackType
  proposedUnitsPerPack    Int
  proposedCaseBarcode     String?
  proposedMultiPackRetail Decimal       @db.Decimal(12, 2)

  unitCostSnapshot      Decimal? @db.Decimal(12, 4)
  aggregateCostSnapshot Decimal? @db.Decimal(12, 4)
  marginSnapshot        Decimal? @db.Decimal(8, 4)

  productVersionSnapshot   Int?
  multiPackVersionSnapshot Int?

  submittedByActorId String?
  submittedAt        DateTime @default(now())

  reviewedByActorId String?
  reviewedAt        DateTime?
  reviewNote        String?
  rejectionReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, status, submittedAt])
  @@index([storeId, productId, status])
  @@index([targetMultiPackId, status])
  @@index([submittedByActorId, submittedAt])
}

model Department {
  id                          String               @id @default(uuid())
  name                        String
  posDepartmentNumber         Int
  type                        DepartmentType       @default(merchandise)
  minimumAge                  DepartmentMinimumAge @default(none)
  defaultRetailMargin         Decimal?             @db.Decimal(8, 4)
  minimumRingUpAmount         Decimal?             @db.Decimal(12, 2)
  maximumRingUpAmount         Decimal?             @db.Decimal(12, 2)
  trackInventory              Boolean              @default(true)
  allowNegativeInventorySales Boolean              @default(false)
  allowEbt                    Boolean              @default(false)
  defaultAllowEbt             Boolean              @default(false)
  allowManualRingUp           Boolean              @default(false)
  onPos                       Boolean              @default(true)
  isActive                    Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  defaultTaxId String?
  defaultTax   Tax?    @relation(fields: [defaultTaxId], references: [id])

  products          Product[]
  productCategories ProductCategory[]

  @@unique([storeId, name])
  @@unique([storeId, posDepartmentNumber])
  @@index([storeId, isActive])
  @@index([storeId, onPos, posDepartmentNumber])
  @@index([defaultTaxId])
}

model InventoryLog {
  id              String              @id @default(uuid())
  actionType      InventoryActionType
  quantityBefore  Int
  quantityChanged Int
  quantityAfter   Int
  reason          String
  notes           String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime            @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  performedByStaffId String
  staff              Staff  @relation(fields: [performedByStaffId], references: [id])

  @@index([storeId, createdAt])
  @@index([storeId, productId, createdAt])
  @@index([productId, createdAt])
  @@index([performedByStaffId])
  @@index([actionType])
  @@index([referenceType, referenceId])
}

model PriceGroup {
  id                     String    @id @default(uuid())
  name                   String
  description            String?
  defaultUnitRetail      Decimal   @default(0.00) @db.Decimal(12, 2)
  mismatchedItemCount    Int       @default(0)
  mismatchCountUpdatedAt DateTime?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
  @@index([storeId, mismatchedItemCount])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  brand       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  products Product[]

  @@unique([storeId, departmentId, name])
  @@index([storeId, isActive])
  @@index([departmentId])
}

model Tax {
  id              String   @id @default(uuid())
  name            String
  rate            Float
  surchargeAmount Decimal  @default(0.00) @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products    Product[]
  departments Department[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Payee {
  id               String    @id @default(uuid())
  name             String
  accountNumber    String?
  contactName      String?
  email            String?
  phone            String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  notes            String?
  isActive         Boolean   @default(true)
  payeeType        PayeeType @default(VENDOR)
  allowPosPayments Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  purchases Purchase[]
  productVendors ProductVendor[]
  vendorOrders VendorOrder[]

  @@unique([storeId, name])
  @@index([storeId, isActive, name])
}

model ProductVendor {
  id              String   @id @default(uuid())
  storeId         String
  productId       String
  payeeId         String
  vendorSku       String?
  unitsPerCase    Int      @default(1)
  caseCost        Decimal  @db.Decimal(14, 2)
  caseDiscount    Decimal  @default(0.00) @db.Decimal(14, 2)
  minOrderQuantity Int?
  leadTimeDays    Int?
  isPreferred     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  payee   Payee   @relation(fields: [payeeId], references: [id], onDelete: Cascade)
  vendorOrderItems VendorOrderItem[]

  @@unique([storeId, productId, payeeId])
  @@index([storeId, productId, isActive])
  @@index([storeId, payeeId, isActive])
}

model VendorOrder {
  id                String            @id @default(uuid())
  storeId           String
  payeeId           String
  status            VendorOrderStatus @default(DRAFT)
  estimatedCost     Decimal           @default(0.00) @db.Decimal(14, 2)
  purchaseId        String?
  notes             String?
  sentAt            DateTime?
  receivedAt        DateTime?
  cancelledAt       DateTime?
  createdByActorId  String?
  updatedByActorId  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payee Payee @relation(fields: [payeeId], references: [id])
  items VendorOrderItem[]

  @@index([storeId, status, createdAt])
  @@index([storeId, payeeId, createdAt])
}

model VendorOrderItem {
  id                    String   @id @default(uuid())
  vendorOrderId         String
  productVendorId       String?
  productId             String
  quantityOrdered       Int
  quantityReceived      Int      @default(0)
  unitsPerCase          Int      @default(1)
  caseCost              Decimal  @db.Decimal(14, 2)
  caseDiscount          Decimal  @default(0.00) @db.Decimal(14, 2)
  unitCost              Decimal  @db.Decimal(14, 4)
  extendedCost          Decimal  @db.Decimal(14, 2)
  productNumberSnapshot Int?
  barcodeSnapshot       String?
  productNameSnapshot   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vendorOrder   VendorOrder    @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  productVendor ProductVendor? @relation(fields: [productVendorId], references: [id], onDelete: SetNull)
  product       Product        @relation(fields: [productId], references: [id])

  @@index([vendorOrderId])
  @@index([productId, vendorOrderId])
}

model Purchase {
  id                String         @id @default(uuid())
  purchaseNumber    Int
  invoiceNumber     String
  purchaseDate      DateTime
  type              PurchaseType
  status            PurchaseStatus @default(DRAFT)
  costSubtotal      Decimal        @default(0.00) @db.Decimal(14, 2)
  retailTotal       Decimal        @default(0.00) @db.Decimal(14, 2)
  freightAmount     Decimal        @default(0.00) @db.Decimal(14, 2)
  feeAmount         Decimal        @default(0.00) @db.Decimal(14, 2)
  taxAmount         Decimal        @default(0.00) @db.Decimal(14, 2)
  discountAmount    Decimal        @default(0.00) @db.Decimal(14, 2)
  rebateAmount      Decimal        @default(0.00) @db.Decimal(14, 2)
  totalCost         Decimal        @default(0.00) @db.Decimal(14, 2)
  marginPercent     Decimal?       @db.Decimal(8, 4)
  manualCost        Decimal        @default(0.00) @db.Decimal(14, 2)
  manualRetail      Decimal        @default(0.00) @db.Decimal(14, 2)
  manualMargin      Decimal?       @db.Decimal(8, 4)
  referenceNumber   String?
  notes             String?
  inventoryPostedAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  payeeId String
  payee   Payee  @relation(fields: [payeeId], references: [id])

  createdByActorId String?
  createdByActor   Staff?  @relation("PurchaseCreatedBy", fields: [createdByActorId], references: [id], onDelete: SetNull)

  updatedByActorId String?
  updatedByActor   Staff?  @relation("PurchaseUpdatedBy", fields: [updatedByActorId], references: [id], onDelete: SetNull)

  items    PurchaseItem[]
  expenses PurchaseExpense[]

  @@unique([storeId, purchaseNumber])
  @@unique([storeId, payeeId, invoiceNumber])
  @@index([storeId, purchaseDate])
  @@index([storeId, status, purchaseDate])
  @@index([storeId, payeeId, purchaseDate])
  @@index([storeId, type, purchaseDate])
  @@index([storeId, purchaseNumber])
}

model PurchaseItem {
  id                    String   @id @default(uuid())
  purchaseId            String
  productId             String
  departmentId          String?
  priceGroupId          String?
  categoryId            String?
  quantity              Int
  unitsPerCase          Int      @default(1)
  caseCost              Decimal  @default(0.00) @db.Decimal(14, 2)
  caseDiscount          Decimal  @default(0.00) @db.Decimal(14, 2)
  rebate                Decimal  @default(0.00) @db.Decimal(14, 2)
  entryType             String   @default("purchase")
  source                String?
  unitCost              Decimal  @db.Decimal(14, 4)
  extendedCost          Decimal  @db.Decimal(14, 2)
  unitRetailSnapshot    Decimal  @db.Decimal(14, 2)
  extendedRetail        Decimal  @db.Decimal(14, 2)
  productNumberSnapshot Int?
  barcodeSnapshot       String?
  productNameSnapshot   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId, purchaseId])
  @@index([departmentId])
}

model PurchaseExpense {
  id           String   @id @default(uuid())
  purchaseId   String
  description  String
  amount       Decimal  @db.Decimal(14, 2)
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([departmentId])
}

model Customer {
  id             String   @id @default(uuid())
  customerNumber String   @unique
  email          String?
  firstName      String
  lastName       String
  phone          String   @unique
  rewardPoints   Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stores       CustomerStore[]
  purchases    CustomerPurchaseHistory[]
  transactions Transaction[]
  carts        Cart[]
}

model CustomerStore {
  id        String   @id @default(uuid())
  tier      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  currentTierRuleId String?
  currentTierRule   CustomerTierRule? @relation(fields: [currentTierRuleId], references: [id], onDelete: SetNull)

  currentTierId String?
  currentTier   CustomerTier? @relation(fields: [currentTierId], references: [id], onDelete: SetNull)

  @@unique([customerId, storeId])
  @@index([storeId])
}

model CustomerTier {
  id            String                    @id @default(uuid())
  name          String
  discountModel CustomerTierDiscountModel
  discountValue Decimal                   @db.Decimal(12, 2)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerStores CustomerStore[]
  tierRules      CustomerTierRule[]

  @@unique([storeId, name])
  @@index([ownerId])
  @@index([storeId])
}

model CustomerTierRule {
  id                    String   @id @default(uuid())
  name                  String
  minimumSpend          Decimal  @db.Decimal(12, 2)
  syncAcrossOwnerStores Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tierId String?
  tier   CustomerTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  customerStores CustomerStore[]

  @@index([ownerId, syncAcrossOwnerStores])
  @@index([storeId])
  @@index([tierId])
}

model CustomerPurchaseHistory {
  id            String   @id @default(uuid())
  transactionId String?
  totalSpend    Decimal  @db.Decimal(12, 2)
  purchasedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId, purchasedAt])
  @@index([storeId, purchasedAt])
  @@index([transactionId])
}

model Cart {
  id         String     @id @default(uuid())
  storeId    String
  staffId    String
  customerId String?
  status     CartStatus @default(active)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  items CartItem[]

  @@index([storeId, status, updatedAt])
  @@index([staffId, status])
  @@index([customerId])
}

model CartItem {
  id                  String   @id @default(uuid())
  cartId              String
  productId           String
  quantity            Int
  originalUnitPrice   Decimal  @db.Decimal(12, 2)
  unitPrice           Decimal  @db.Decimal(12, 2)
  priceOverrideReason String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Transaction {
  id                String            @id @default(uuid())
  storeId           String
  staffId           String
  registerId        String?
  customerId        String?
  subtotal          Decimal           @db.Decimal(12, 2)
  discountTotal     Decimal           @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal           @db.Decimal(12, 2)
  total             Decimal           @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus     @default(paid)
  transactionStatus TransactionStatus @default(completed)
  receiptNumber     String            @unique
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  register Register? @relation(fields: [registerId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  items   TransactionItem[]
  receipt Receipt?

  @@index([storeId, createdAt])
  @@index([storeId, transactionStatus, createdAt])
  @@index([registerId])
  @@index([storeId, registerId, createdAt])
  @@index([staffId, createdAt])
  @@index([customerId, createdAt])
}

model TransactionItem {
  id              String   @id @default(uuid())
  transactionId   String
  productId       String
  nameSnapshot    String
  barcodeSnapshot String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  lineSubtotal    Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @db.Decimal(12, 2)
  lineTotal       Decimal  @db.Decimal(12, 2)
  taxStyle        TaxStyle
  createdAt       DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@index([productId, transactionId])
}

model Receipt {
  id            String   @id @default(uuid())
  transactionId String   @unique
  receiptNumber String   @unique
  receiptData   Json
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
