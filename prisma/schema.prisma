generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  owner
  partner
  manager
  employee
}

enum SubscriptionStatus {
  trial
  active
  inactive
  cancelled
}

enum BillingCycle {
  monthly
  annual
}

enum ProductSaleType {
  piece
  weight
  meat_barcode
  service
  lottery
  other
}

enum TaxStyle {
  pre_discount
  post_discount
}

enum InventoryActionType {
  receive
  adjustment
  sale
  return
  spoilage
  waste
  transfer_in
  transfer_out
  manual_edit
}

enum CustomerTierDiscountModel {
  ORDER_PERCENTAGE
  ORDER_FLAT_RATE
  ITEM_PERCENTAGE
  ITEM_FLAT_RATE
}

model Staff {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  role            StaffRole
  emailVerifiedAt DateTime?

  owner    Owner?
  partner  Partner?
  manager  Manager?
  employee Employee?

  storeStaff              StoreStaff[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  inventoryLogs           InventoryLog[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model Owner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  stores Store[]

  subscriptions     Subscription[]
  customerTiers     CustomerTier[]
  customerTierRules CustomerTierRule[]
}

model Partner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Manager {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  permissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Employee {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Store {
  id      String  @id @default(uuid())
  name    String
  address String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  staff                   StoreStaff[]
  products                Product[]
  inventoryLogs           InventoryLog[]
  departments             Department[]
  priceGroups             PriceGroup[]
  productCategories       ProductCategory[]
  taxes                   Tax[]
  customers               CustomerStore[]
  customerTiers           CustomerTier[]
  customerTierRules       CustomerTierRule[]
  customerPurchaseHistory CustomerPurchaseHistory[]

  @@index([ownerId, isActive])
}

model StoreStaff {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  role StaffRole

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  managerId String?
  manager   Manager? @relation(fields: [managerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([storeId, staffId])
}

model Subscription {
  id String @id @default(uuid())

  status              SubscriptionStatus @default(trial)
  billingCycle        BillingCycle
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  maxStores           Int?
  activeStoreCount    Int                @default(0)
  pricePerStore       Float              @default(0)
  totalMonthlyAmount  Float              @default(0)
  totalAnnualAmount   Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  @@index([ownerId, status])
}

model Product {
  id                             String          @id @default(uuid())
  barcode                        String          @unique
  name                           String
  saleType                       ProductSaleType
  currentQuantity                Int             @default(0)
  unitsPerCase                   Int?
  caseCost                       Float?
  caseDiscount                   Float           @default(0)
  discountPerUnit                Float?
  caseRebate                     Float           @default(0)
  rebatePerUnit                  Float?
  unitCost                       Float?
  unitCostAfterDiscountAndRebate Float?
  unitRetail                     Float
  onlineRetailPrice              Float?
  unitOfMeasure                  String?
  size                           String?
  margin                         Float?
  defaultMargin                  Float?
  maxInventory                   Int?
  minInventory                   Int?
  minimumAge                     Int?
  nacsCode                       String?
  nacsCategory                   String?
  nacsSubCategory                String?
  blueLaw                        Boolean         @default(false)
  linkedItems                    Json?
  kitchenPrint                   Boolean         @default(false)
  allowEbt                       Boolean
  trackInventory                 Boolean         @default(true)
  allowNegativeInventory         Boolean         @default(false)
  taxStyle                       TaxStyle
  isActive                       Boolean         @default(true)
  createdAt                      DateTime        @default(now())
  updatedAt                      DateTime        @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id])

  productCategoryId String
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id])

  taxId String
  tax   Tax    @relation(fields: [taxId], references: [id])

  inventoryLogs InventoryLog[]

  @@index([storeId, isActive])
  @@index([departmentId])
  @@index([priceGroupId])
  @@index([productCategoryId])
  @@index([taxId])
}

model Department {
  id              String   @id @default(uuid())
  name            String
  defaultAllowEbt Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model InventoryLog {
  id              String              @id @default(uuid())
  actionType      InventoryActionType
  quantityBefore  Int
  quantityChanged Int
  quantityAfter   Int
  reason          String
  notes           String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime            @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  performedByStaffId String
  staff              Staff  @relation(fields: [performedByStaffId], references: [id])

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([performedByStaffId])
  @@index([actionType])
  @@index([referenceType, referenceId])
}

model PriceGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  brand       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Tax {
  id        String   @id @default(uuid())
  name      String
  rate      Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Customer {
  id             String   @id @default(uuid())
  customerNumber String   @unique
  email          String?
  firstName      String
  lastName       String
  phone          String   @unique
  rewardPoints   Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stores    CustomerStore[]
  purchases CustomerPurchaseHistory[]
}

model CustomerStore {
  id        String   @id @default(uuid())
  tier      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  currentTierRuleId String?
  currentTierRule   CustomerTierRule? @relation(fields: [currentTierRuleId], references: [id], onDelete: SetNull)

  currentTierId String?
  currentTier   CustomerTier? @relation(fields: [currentTierId], references: [id], onDelete: SetNull)

  @@unique([customerId, storeId])
  @@index([storeId])
}

model CustomerTier {
  id            String                    @id @default(uuid())
  name          String
  discountModel CustomerTierDiscountModel
  discountValue Decimal                   @db.Decimal(12, 2)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerStores CustomerStore[]
  tierRules      CustomerTierRule[]

  @@unique([storeId, name])
  @@index([ownerId])
  @@index([storeId])
}

model CustomerTierRule {
  id                    String   @id @default(uuid())
  name                  String
  minimumSpend          Decimal  @db.Decimal(12, 2)
  syncAcrossOwnerStores Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tierId String?
  tier   CustomerTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  customerStores CustomerStore[]

  @@index([ownerId, syncAcrossOwnerStores])
  @@index([storeId])
  @@index([tierId])
}

model CustomerPurchaseHistory {
  id            String   @id @default(uuid())
  transactionId String?
  totalSpend    Decimal  @db.Decimal(12, 2)
  purchasedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId, purchasedAt])
  @@index([storeId, purchasedAt])
  @@index([transactionId])
}
