generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  owner
  partner
  manager
  employee
}

enum CustomerTierDiscountModel {
  ORDER_PERCENTAGE
  ORDER_FLAT_RATE
  ITEM_PERCENTAGE
  ITEM_FLAT_RATE
}

model Staff {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  role            StaffRole
  emailVerifiedAt DateTime?

  owner    Owner?
  partner  Partner?
  manager  Manager?
  employee Employee?

  storeStaff              StoreStaff[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model Owner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  stores Store[]

  subscriptions     Subscription[]
  customerTiers     CustomerTier[]
  customerTierRules CustomerTierRule[]
}

model Partner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Manager {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  permissions Json?

  createdAt DateTime @default(now())

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Employee {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Store {
  id      String  @id @default(uuid())
  name    String
  address String?

  createdAt DateTime @default(now())

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  staff                   StoreStaff[]
  products                Product[]
  customers               CustomerStore[]
  customerTiers           CustomerTier[]
  customerTierRules       CustomerTierRule[]
  customerPurchaseHistory CustomerPurchaseHistory[]
}

model StoreStaff {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  role StaffRole

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  managerId String?
  manager   Manager? @relation(fields: [managerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([storeId, staffId])
}

model Subscription {
  id String @id @default(uuid())

  status        String    @default("trial")
  billingCycle  String?
  pricePerStore Float?
  trialEndsAt   DateTime?

  createdAt DateTime @default(now())

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])
}

model Product {
  id      String @id @default(uuid())
  name    String
  barcode String @unique
  price   Float

  stock Int @default(0)

  createdAt DateTime @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
}

model Customer {
  id             String   @id @default(uuid())
  customerNumber String   @unique
  email          String?
  firstName      String
  lastName       String
  phone          String   @unique
  rewardPoints   Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stores    CustomerStore[]
  purchases CustomerPurchaseHistory[]
}

model CustomerStore {
  id        String   @id @default(uuid())
  tier      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  currentTierRuleId String?
  currentTierRule   CustomerTierRule? @relation(fields: [currentTierRuleId], references: [id], onDelete: SetNull)

  currentTierId String?
  currentTier   CustomerTier? @relation(fields: [currentTierId], references: [id], onDelete: SetNull)

  @@unique([customerId, storeId])
  @@index([storeId])
}

model CustomerTier {
  id            String                    @id @default(uuid())
  name          String
  discountModel CustomerTierDiscountModel
  discountValue Decimal                   @db.Decimal(12, 2)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerStores CustomerStore[]
  tierRules      CustomerTierRule[]

  @@unique([storeId, name])
  @@index([ownerId])
  @@index([storeId])
}

model CustomerTierRule {
  id                    String   @id @default(uuid())
  name                  String
  minimumSpend          Decimal  @db.Decimal(12, 2)
  syncAcrossOwnerStores Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tierId String?
  tier   CustomerTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  customerStores CustomerStore[]

  @@index([ownerId, syncAcrossOwnerStores])
  @@index([storeId])
  @@index([tierId])
}

model CustomerPurchaseHistory {
  id            String   @id @default(uuid())
  transactionId String?
  totalSpend    Decimal  @db.Decimal(12, 2)
  purchasedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId, purchasedAt])
  @@index([storeId, purchasedAt])
  @@index([transactionId])
}
