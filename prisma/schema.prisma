generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  owner
  partner
  manager
  employee
}

enum SubscriptionStatus {
  trial
  active
  inactive
  cancelled
}

enum BillingCycle {
  monthly
  annual
}

enum ProductSaleType {
  piece
  weight
  meat_barcode
  service
  lottery
  other
}

enum TaxStyle {
  pre_discount
  post_discount
}

enum PaymentMethod {
  cash
  card
  ebt
  split
  other
}

enum PaymentStatus {
  paid
  unpaid
  refunded
  partially_refunded
}

enum TransactionStatus {
  completed
  voided
  refunded
  partially_refunded
}

enum CartStatus {
  active
  ready_for_payment
  completed
  cancelled
}

enum InventoryActionType {
  receive
  adjustment
  sale
  return
  spoilage
  waste
  transfer_in
  transfer_out
  manual_edit
}

enum CustomerTierDiscountModel {
  ORDER_PERCENTAGE
  ORDER_FLAT_RATE
  ITEM_PERCENTAGE
  ITEM_FLAT_RATE
}

enum StorePermissionKey {
  view_store
  add_store
  edit_store
  delete_store
  manage_products
  manage_inventory
  manage_customers
  manage_employees
  view_reports
  process_sales
  override_prices
}

model Staff {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  role            StaffRole
  emailVerifiedAt DateTime?

  owner    Owner?
  partner  Partner?
  manager  Manager?
  employee Employee?

  storeStaff              StoreStaff[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  inventoryLogs           InventoryLog[]
  transactions            Transaction[]
  carts                   Cart[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  type      StaffRole
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, type])
  @@index([expiresAt])
}

model Owner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  stores Store[]

  subscriptions     Subscription[]
  customerTiers     CustomerTier[]
  customerTierRules CustomerTierRule[]
}

model Partner {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Manager {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  permissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Employee {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffId String @unique
  staff   Staff  @relation(fields: [staffId], references: [id])

  storeStaff StoreStaff[]
}

model Store {
  id      String  @id @default(uuid())
  name    String
  address String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  staff                   StoreStaff[]
  products                Product[]
  inventoryLogs           InventoryLog[]
  departments             Department[]
  priceGroups             PriceGroup[]
  productCategories       ProductCategory[]
  taxes                   Tax[]
  customers               CustomerStore[]
  customerTiers           CustomerTier[]
  customerTierRules       CustomerTierRule[]
  customerPurchaseHistory CustomerPurchaseHistory[]
  transactions            Transaction[]
  carts                   Cart[]

  @@index([ownerId, isActive])
}

model StoreStaff {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  role StaffRole

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  managerId String?
  manager   Manager? @relation(fields: [managerId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  permissions StoreStaffPermission[]

  @@unique([storeId, staffId])
}

model StoreStaffPermission {
  id           String             @id @default(uuid())
  storeStaffId String
  permission   StorePermissionKey
  createdAt    DateTime           @default(now())

  storeStaff StoreStaff @relation(fields: [storeStaffId], references: [id], onDelete: Cascade)

  @@unique([storeStaffId, permission])
  @@index([storeStaffId])
}

model Subscription {
  id String @id @default(uuid())

  status              SubscriptionStatus @default(trial)
  billingCycle        BillingCycle
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  maxStores           Int?
  activeStoreCount    Int                @default(0)
  pricePerStore       Float              @default(0)
  totalMonthlyAmount  Float              @default(0)
  totalAnnualAmount   Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  @@index([ownerId, status])
}

model Product {
  id                             String          @id @default(uuid())
  barcode                        String          @unique
  name                           String
  saleType                       ProductSaleType
  currentQuantity                Int             @default(0)
  unitsPerCase                   Int?
  caseCost                       Float?
  caseDiscount                   Float           @default(0)
  discountPerUnit                Float?
  caseRebate                     Float           @default(0)
  rebatePerUnit                  Float?
  unitCost                       Float?
  unitCostAfterDiscountAndRebate Float?
  unitRetail                     Float
  onlineRetailPrice              Float?
  unitOfMeasure                  String?
  size                           String?
  margin                         Float?
  defaultMargin                  Float?
  maxInventory                   Int?
  minInventory                   Int?
  minimumAge                     Int?
  nacsCode                       String?
  nacsCategory                   String?
  nacsSubCategory                String?
  blueLaw                        Boolean         @default(false)
  linkedItems                    Json?
  kitchenPrint                   Boolean         @default(false)
  allowEbt                       Boolean
  trackInventory                 Boolean         @default(true)
  allowNegativeInventory         Boolean         @default(false)
  taxStyle                       TaxStyle
  isActive                       Boolean         @default(true)
  createdAt                      DateTime        @default(now())
  updatedAt                      DateTime        @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id])

  productCategoryId String
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id])

  taxId String
  tax   Tax    @relation(fields: [taxId], references: [id])

  inventoryLogs    InventoryLog[]
  transactionItems TransactionItem[]
  cartItems        CartItem[]

  @@index([storeId, isActive])
  @@index([departmentId])
  @@index([priceGroupId])
  @@index([productCategoryId])
  @@index([taxId])
}

model Department {
  id              String   @id @default(uuid())
  name            String
  defaultAllowEbt Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model InventoryLog {
  id              String              @id @default(uuid())
  actionType      InventoryActionType
  quantityBefore  Int
  quantityChanged Int
  quantityAfter   Int
  reason          String
  notes           String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime            @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  performedByStaffId String
  staff              Staff  @relation(fields: [performedByStaffId], references: [id])

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([performedByStaffId])
  @@index([actionType])
  @@index([referenceType, referenceId])
}

model PriceGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  brand       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Tax {
  id        String   @id @default(uuid())
  name      String
  rate      Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Customer {
  id             String   @id @default(uuid())
  customerNumber String   @unique
  email          String?
  firstName      String
  lastName       String
  phone          String   @unique
  rewardPoints   Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stores       CustomerStore[]
  purchases    CustomerPurchaseHistory[]
  transactions Transaction[]
  carts        Cart[]
}

model CustomerStore {
  id        String   @id @default(uuid())
  tier      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  currentTierRuleId String?
  currentTierRule   CustomerTierRule? @relation(fields: [currentTierRuleId], references: [id], onDelete: SetNull)

  currentTierId String?
  currentTier   CustomerTier? @relation(fields: [currentTierId], references: [id], onDelete: SetNull)

  @@unique([customerId, storeId])
  @@index([storeId])
}

model CustomerTier {
  id            String                    @id @default(uuid())
  name          String
  discountModel CustomerTierDiscountModel
  discountValue Decimal                   @db.Decimal(12, 2)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerStores CustomerStore[]
  tierRules      CustomerTierRule[]

  @@unique([storeId, name])
  @@index([ownerId])
  @@index([storeId])
}

model CustomerTierRule {
  id                    String   @id @default(uuid())
  name                  String
  minimumSpend          Decimal  @db.Decimal(12, 2)
  syncAcrossOwnerStores Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tierId String?
  tier   CustomerTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  customerStores CustomerStore[]

  @@index([ownerId, syncAcrossOwnerStores])
  @@index([storeId])
  @@index([tierId])
}

model CustomerPurchaseHistory {
  id            String   @id @default(uuid())
  transactionId String?
  totalSpend    Decimal  @db.Decimal(12, 2)
  purchasedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId, purchasedAt])
  @@index([storeId, purchasedAt])
  @@index([transactionId])
}

model Cart {
  id         String     @id @default(uuid())
  storeId    String
  staffId    String
  customerId String?
  status     CartStatus @default(active)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  items CartItem[]

  @@index([storeId, status, updatedAt])
  @@index([staffId, status])
  @@index([customerId])
}

model CartItem {
  id                  String   @id @default(uuid())
  cartId              String
  productId           String
  quantity            Int
  originalUnitPrice   Decimal  @db.Decimal(12, 2)
  unitPrice           Decimal  @db.Decimal(12, 2)
  priceOverrideReason String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Transaction {
  id                String            @id @default(uuid())
  storeId           String
  staffId           String
  customerId        String?
  subtotal          Decimal           @db.Decimal(12, 2)
  discountTotal     Decimal           @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal           @db.Decimal(12, 2)
  total             Decimal           @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus     @default(paid)
  transactionStatus TransactionStatus @default(completed)
  receiptNumber     String            @unique
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  items   TransactionItem[]
  receipt Receipt?

  @@index([storeId, createdAt])
  @@index([staffId, createdAt])
  @@index([customerId, createdAt])
}

model TransactionItem {
  id              String   @id @default(uuid())
  transactionId   String
  productId       String
  nameSnapshot    String
  barcodeSnapshot String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  lineSubtotal    Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @db.Decimal(12, 2)
  lineTotal       Decimal  @db.Decimal(12, 2)
  taxStyle        TaxStyle
  createdAt       DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Receipt {
  id            String   @id @default(uuid())
  transactionId String   @unique
  receiptNumber String   @unique
  receiptData   Json
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
